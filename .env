# ── App Config ─────────────────────────────
APP_NAME=HealthPulse API
APP_VERSION=2.0.0

# ── CORS ───────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/healthpulse

# ── JWT (if using auth) ────────────────────
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60